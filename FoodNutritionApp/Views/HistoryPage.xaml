<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FoodNutritionApp.ViewModels"
             xmlns:models="clr-namespace:FoodNutritionApp.Models"
             x:Class="FoodNutritionApp.Views.HistoryPage"
             x:DataType="vm:HistoryViewModel"
             Title="{Binding Title}"
             BackgroundColor="{DynamicResource Background}">

    <Grid RowDefinitions="Auto,Auto,*" Padding="16">
        <VerticalStackLayout Grid.Row="0" Spacing="8" Margin="0,0,0,8">
            <Label Text="Filter by category"
                   FontSize="14"
                   TextColor="{DynamicResource TextSecondary}" />
            <Picker ItemsSource="{Binding CategoryOptions}"
                    SelectedItem="{Binding SelectedCategory}"
                    Title="Select category"
                    FontSize="{DynamicResource FontSizeBody}" />
        </VerticalStackLayout>

        <HorizontalStackLayout Grid.Row="1" Spacing="8" Margin="0,0,0,12">
            <Button Text="Clear All"
                    Command="{Binding ClearAllCommand}"
                    BackgroundColor="{StaticResource Error}"
                    TextColor="White"
                    SemanticProperties.Description="Clear all food records" />
        </HorizontalStackLayout>

        <RefreshView Grid.Row="2"
                     IsRefreshing="{Binding IsBusy}"
                     Command="{Binding RefreshCommand}">
            <CollectionView ItemsSource="{Binding Records}"
                            SelectionMode="None">
                <CollectionView.EmptyView>
                    <Label Text="No records in this category."
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           FontSize="{DynamicResource FontSizeBody}"
                           TextColor="{DynamicResource TextSecondary}" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:HistoryRecord">
                        <SwipeView>
                            <SwipeView.RightItems>
                                <SwipeItems Mode="Execute">
                                    <SwipeItem Text="Edit"
                                               BackgroundColor="{StaticResource Accent}"
                                               Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HistoryViewModel}}, Path=EditRecordCommand}"
                                               CommandParameter="{Binding .}" />
                                    <SwipeItem Text="Delete"
                                               BackgroundColor="{StaticResource Error}"
                                               Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HistoryViewModel}}, Path=DeleteRecordCommand}"
                                               CommandParameter="{Binding .}" />
                                </SwipeItems>
                            </SwipeView.RightItems>
                            <Frame Padding="14" Margin="0,4" CornerRadius="12" BackgroundColor="{DynamicResource Surface}" BorderColor="{StaticResource PrimaryLight}">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HistoryViewModel}}, Path=OpenRecordCommand}"
                                                          CommandParameter="{Binding .}" />
                                </Frame.GestureRecognizers>
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto">
                                    <Label Grid.Row="0" Grid.Column="0"
                                           Text="{Binding FoodName}"
                                           FontSize="{DynamicResource FontSizeBody}"
                                           FontAttributes="Bold"
                                           TextColor="{DynamicResource TextPrimary}" />
                                    <Label Grid.Row="0" Grid.Column="1"
                                           Text="{Binding Category}"
                                           FontSize="12"
                                           TextColor="{StaticResource AccentDark}" />
                                    <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                           Text="{Binding Source, StringFormat='Source: {0}'}"
                                           FontSize="12"
                                           TextColor="{DynamicResource TextSecondary}" />
                                    <Label Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                           FontSize="14"
                                           TextColor="{DynamicResource TextSecondary}">
                                        <Label.Text>
                                            <MultiBinding StringFormat="{}{0:F0} kcal · Protein {1:F1}g">
                                                <Binding Path="Calories" />
                                                <Binding Path="Protein" />
                                            </MultiBinding>
                                        </Label.Text>
                                    </Label>
                                    <Label Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                           Text="{Binding SavedAt, StringFormat='Saved: {0:g}'}"
                                           FontSize="12"
                                           TextColor="{DynamicResource TextSecondary}" />
                                </Grid>
                            </Frame>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
